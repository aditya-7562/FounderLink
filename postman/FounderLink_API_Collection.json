      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Attach JWT token to every request if available",
          "const token = pm.environment.get('jwtToken');",
          "if (token) {",
          "    pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
